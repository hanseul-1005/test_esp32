<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/configRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- SSID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SSID"
            android:textSize="13sp"
            android:textColor="#333333"
            android:paddingBottom="2dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etSsid"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:inputType="text"
                android:background="@drawable/input_border"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"/>

            <Button
                android:id="@+id/btnSelectSsid"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:text="목록"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="13sp"
            android:textColor="#333333"
            android:paddingTop="8dp"
            android:paddingBottom="2dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:inputType="textPassword"
            android:background="@drawable/input_border"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>

        <CheckBox
            android:id="@+id/cbShowPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Show Password"
            android:textSize="13sp"/>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:background="#DDDDDD"/>

        <!-- API Server IP -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Server IP"
            android:textSize="13sp"
            android:textColor="#333333"
            android:paddingBottom="2dp"/>

        <EditText
            android:id="@+id/etApiIp"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:inputType="textUri"
            android:background="@drawable/input_border"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>

        <!-- API Port -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Port"
            android:textSize="13sp"
            android:textColor="#333333"
            android:paddingTop="8dp"
            android:paddingBottom="2dp"/>

        <EditText
            android:id="@+id/etApiPort"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:inputType="number"
            android:text="443"
            android:background="@drawable/input_border"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>

        <!-- API Path -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Path"
            android:textSize="13sp"
            android:textColor="#333333"
            android:paddingTop="8dp"
            android:paddingBottom="2dp"/>

        <EditText
            android:id="@+id/etApiPath"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:inputType="text"
            android:text="/papi/v1/sensor"
            android:background="@drawable/input_border"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:background="#DDDDDD"/>

        <!-- Device Code -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Device Code"
            android:textSize="13sp"
            android:textColor="#333333"
            android:paddingBottom="2dp"/>

        <EditText
            android:id="@+id/etDeviceCode"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:inputType="text"
            android:background="@drawable/input_border"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>

        <!-- Product Code -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product Code"
            android:textSize="13sp"
            android:textColor="#333333"
            android:paddingTop="8dp"
            android:paddingBottom="2dp"/>

        <EditText
            android:id="@+id/etProductCode"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:inputType="text"
            android:background="@drawable/input_border"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>

        <!-- 상태 메시지 -->
        <TextView
            android:id="@+id/tvConfigStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"/>

        <!-- Save 버튼 -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Save"
            android:textSize="16sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
